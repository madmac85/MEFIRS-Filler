{
  "manifest_version": 3,
  "name": "MEFIRS Filler",
  "version": "1.6.0",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [ "https://www.mefirs.org/*" ],
      "js": [ "contentScript.js" ],
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
